### Test 11: Invalid Dimension Format

```json
{
  "name": "throws_error_for_invalid_dimensions",
  "description": "Should throw error for malformed dimension string",
  "testCases": [
    {
      "input_dims": "10x8",
      "expected_error": "Invalid dimension format: must be LxWxH"
    },
    {
      "input_dims": "axbxc",
      "expected_error": "Invalid dimension format: dimensions must be numbers"
    },
    {
      "input_dims": "10x0x6",
      "expected_error": "All dimensions must be greater than 0"
    },
    {
      "input_dims": "",
      "expected_error": "Dimensions cannot be empty"
    }
  ]
}
```

### Test 12: Invalid Email Format

```json
{
  "name": "throws_error_for_invalid_email",
  "description": "Should throw error for invalid email format",
  "testCases": [
    {
      "input_email": "not-an-email",
      "expected_error": "Invalid email format"
    },
    {
      "input_email": "@example.com",
      "expected_error": "Invalid email format"
    },
    {
      "input_email": "user@",
      "expected_error": "Invalid email format"
    }
  ]
}
```

## Edge Case Tests

### Test 13: Canadian Address

```json
{
  "name": "handles_canadian_address",
  "description": "Correctly transforms Canadian postal code and province",
  "input": {
    "orderNumber": "ORD-2026-005",
    "orderDate": "2026-01-15T14:00:00Z",
    "customer": {
      "custId": "CUST-CA-001",
      "fullName": "David Smith",
      "email": "david@example.ca",
      "shippingAddr": {
        "street1": "123 Yonge Street",
        "city": "Toronto",
        "state": "ON",
        "zip": "M5B 2H1",
        "country": "CA"
      }
    },
    "items": [
      {
        "sku": "CA-PROD-001",
        "description": "Canadian Product",
        "qty": 1,
        "weight_oz": 16,
        "dims": "10x8x6"
      }
    ],
    "shipFromWarehouse": "DC-CANADA-01",
    "requestedShipDate": "2026-01-16",
    "serviceLevel": "GROUND"
  },
  "expected": {
    "destination_address": {
      "state": "ON",
      "postal_code": "M5B 2H1",
      "country": "CA"
    }
  },
  "note": "Should preserve Canadian postal code format"
}
```

