## Weight Conversion Tests

### Test 4: Decimal Weight Conversion

```json
{
  "name": "converts_decimal_ounces_to_pounds",
  "description": "Correctly converts fractional ounces to pounds",
  "input": {
    "orderNumber": "ORD-2026-004",
    "orderDate": "2026-01-15T13:00:00Z",
    "customer": {
      "custId": "CUST-111",
      "fullName": "Alice Williams",
      "email": "alice@example.com",
      "shippingAddr": {
        "street1": "111 Maple Dr",
        "city": "Austin",
        "state": "TX",
        "zip": "78701",
        "country": "US"
      }
    },
    "items": [
      {
        "sku": "LIGHT-001",
        "description": "Light Item",
        "qty": 1,
        "weight_oz": 12.5,
        "dims": "5x4x3"
      }
    ],
    "shipFromWarehouse": "DC-CENTRAL-01",
    "requestedShipDate": "2026-01-16",
    "serviceLevel": "OVERNIGHT"
  },
  "expected": {
    "items": [
      {
        "weight": {
          "value": 0.78125,
          "unit": "lb"
        }
      }
    ]
  },
  "note": "12.5 oz / 16 = 0.78125 lb - partial object shown for brevity"
}
```

### Test 5: Various Weight Conversions

```json
{
  "testCases": [
    {
      "input_weight_oz": 8,
      "expected_weight_lb": 0.5,
      "note": "8 oz = 0.5 lb"
    },
    {
      "input_weight_oz": 16,
      "expected_weight_lb": 1.0,
      "note": "16 oz = 1 lb"
    },
    {
      "input_weight_oz": 32,
      "expected_weight_lb": 2.0,
      "note": "32 oz = 2 lb"
    },
    {
      "input_weight_oz": 48,
      "expected_weight_lb": 3.0,
      "note": "48 oz = 3 lb"
    }
  ]
}
```

## Dimension Parsing Tests

### Test 6: Dimensions with Spaces

```json
{
  "name": "parses_dimensions_with_spaces",
  "description": "Handles dimension strings with various spacing",
  "testCases": [
    {
      "input": "10x8x6",
      "expected": {"length": 10, "width": 8, "height": 6, "unit": "in"}
    },
    {
      "input": "10 x 8 x 6",
      "expected": {"length": 10, "width": 8, "height": 6, "unit": "in"}
    },
    {
      "input": "10 x8x 6",
      "expected": {"length": 10, "width": 8, "height": 6, "unit": "in"}
    },
    {
      "input": "12x10x8",
      "expected": {"length": 12, "width": 10, "height": 8, "unit": "in"}
    }
  ]
}
```

## Validation Error Tests

### Test 7: Missing Required Field - orderNumber

```json
{
  "name": "throws_error_for_missing_order_number",
  "description": "Should throw validation error when orderNumber is missing",
  "input": {
    "orderDate": "2026-01-15T10:00:00Z",
    "customer": {
      "custId": "CUST-001",
      "fullName": "Test User",
      "email": "test@example.com",
      "shippingAddr": {
        "street1": "123 Test St",
        "city": "TestCity",
        "state": "CA",
        "zip": "90001",
        "country": "US"
      }
    },
    "items": [
      {
        "sku": "TEST-001",
        "description": "Test",
        "qty": 1,
        "weight_oz": 16,
        "dims": "10x8x6"
      }
    ],
    "shipFromWarehouse": "DC-01",
    "requestedShipDate": "2026-01-16",
    "serviceLevel": "GROUND"
  },
  "expected_error": {
    "message": "Missing required field: orderNumber",
    "type": "ValidationError"
  }
}
```

